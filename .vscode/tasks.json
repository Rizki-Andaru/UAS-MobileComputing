{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run-ai-backend",
            "type": "shell",
            "command": "python AutoCare_UTS/api_server.py",
            "isBackground": true,
            "problemMatcher": {
                "owner": "python",
                "pattern": {
                    "regexp": "^(.*)$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Running on http://localhost:5000",
                    "endsPattern": "Running on http://localhost:5000"
                }
            },
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}
